# Zugangsdaten fuer die clientseitige Login-Sperre der Applikation.
#
# Lokal: Diese Datei nach ".env.local" kopieren und Werte eintragen.
#        (.env.local ist via *.local in .gitignore von Git ausgeschlossen.)
# Vercel: Diese beiden Variablen unter
#        Project -> Settings -> Environment Variables setzen und neu deployen.
#
# Hinweis: Reine Client-SPA ohne Backend. Die Werte landen beim Build im
# JavaScript-Bundle und sind im Browser auslesbar -> einfache Zugangssperre,
# keine echte Sicherheit. Sind beide Variablen leer/ungesetzt, ist die App
# ohne Login zugaenglich.

VITE_APP_USER=
VITE_APP_PASSWORD=
