# Serverseitige Auth fuer den /api/auth-Endpoint (Vercel Edge Function).
#
# WICHTIG: Diese Variablen haben KEINEN VITE_-Praefix. Dadurch landen sie NICHT
# im Browser-Bundle, sondern existieren nur auf dem Server -> das Passwort ist
# nicht im ausgelieferten Code auslesbar.
#
# Lokal:  Diese Datei nach ".env.local" kopieren, Werte eintragen und die App
#         mit "vercel dev" starten (NICHT "npm run dev" -> dort laufen die
#         /api-Funktionen nicht).
# Vercel: Diese Variablen unter Project -> Settings -> Environment Variables
#         setzen und neu deployen.

APP_USER=
APP_PASSWORD=
# Langer Zufallsstring zum Signieren des Session-Tokens, z. B. via
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
